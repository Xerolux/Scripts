# Konfiguration für das lokale Repository-Skript

REPO_DIR="/var/local/custom-repo"
LOG_FILE="/var/log/setup_local_repo.log"

DOVECOT_PKG_DIR="/root/dovecot-packages"
POSTFIX_PKG_DIR="/root/postfix-packages"
NGINX_PKG_DIR="/root/nginx-packages"
PHP_PKG_DIR="/root/php-packages"

# GPG-Signierung
# GPG_KEY_ID=""                    # Leer = auto (verwendet den einzigen Secret-Key)
# GPG_KEY_NAME="Custom Build Repo" # Name fuer den GPG-Schluessel
# GPG_KEY_EMAIL="root@localhost"   # E-Mail fuer den GPG-Schluessel
# GPG_KEYRING_DIR="/root/.gnupg"   # GPG-Keyring-Verzeichnis
